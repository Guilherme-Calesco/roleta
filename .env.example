# Banco de dados
MONGODB_URI=mongodb://localhost:27017/casamento-emillene-caio

# Dados do PIX dos noivos
PIX_KEY=chave-pix-aqui
PIX_RECEIVER_NAME=NOME RECEBEDOR
PIX_RECEIVER_CITY=CIDADE

# Personalização do casamento
COUPLE_NAMES=Emillene & Caio
WEDDING_DATE=2026-12-31
WEDDING_HASHTAG=#EmilleneECaio

# Regra do prêmio master
MASTER_THRESHOLD=500
MASTER_AWARD_MODE=once
MASTER_CHANCE_PERCENT=10

# Acesso oculto da rota dos noivos
ADMIN_HASH=troque-este-valor-por-uma-string-secreta-grande

# URL pública (importante: setar com a URL do Railway em produção)
BASE_URL=http://localhost:3000

# Sessão
SESSION_SECRET=troque-este-segredo

# Porta
PORT=3000
